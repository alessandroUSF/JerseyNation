
@page
@model ERDModel
@{
    ViewData["Title"] = "ERD";
}

<section class="erd-page-hero mb-4">
    <div class="erd-wrap">
        <span class="erd-pill">JerseyNation • Assignment 3</span>
        <h1>JerseyNation ERD Diagram</h1>
        <p>
            This page presents the logical data model used in JerseyNation. Hover a block to preview key details and click a block
            to refresh the data dictionary and relationship panel below. The visual structure is based on the uploaded ERD reference file.
        </p>
        <div class="hero-actions">
            <a class="btn btn-erd-primary" asp-page="/About">Back to About</a>
            <a class="btn btn-erd-outline" href="#dictionary">Data Dictionary</a>
        </div>
    </div>
</section>

<section class="erd-wrap">
    <div class="erd-intro">
        <div><strong>Student</strong><br />Alessandro Luiz Sica de Almeida</div>
        <div><strong>Logical Data Model</strong><br />Business-domain ERD with PK and FK connectors, hover previews, and full data dictionary.</div>
        <div><strong>Note</strong><br />Clicking each block updates the technical detail area below.</div>
    </div>

    <section class="diagram-card">
        <h2 class="diagram-title">Business-block ERD view</h2>
        <p class="diagram-text">
            The layout below keeps the business blocks grouped around the central order domain to make relationships easier to read.
        </p>
        <p class="hint">Hover a block to preview richer table detail. Click a block to refresh the full detail panel below.</p>

        <div class="diagram" id="diagram">
            <svg class="svg-layer" id="svgLayer"></svg>

            <div class="diagram-grid">
                <div class="title-card">
                    <div>
                        <h2>JerseyNation<br />ERD Diagram</h2>
                        <p>Business-domain view with PK and FK connectors</p>
                    </div>
                </div>

                <article class="block admin" data-id="admin">
                    <div class="badge" style="background:var(--admin)">AD</div>
                    <h3>Administration &amp; Governance</h3>
                    <p>Internal users, permissions, auditability, and system control.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">UserID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">PermissionID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">UpdatedByUserID → Order</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini">No mandatory external API</span></div>
                    <div class="tooltip" id="tt-admin"></div>
                </article>

                <article class="block supplier" data-id="supplier">
                    <div class="badge" style="background:var(--supplier)">SU</div>
                    <h3>Supplier &amp; Procurement</h3>
                    <p>Supplier records, purchase orders, and inbound inventory flow.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">SupplierID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">SupplierOrderID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">ProductID → Catalog</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini api">Supplier / EDI API</span><span class="mini api">Inventory Sync API</span></div>
                    <div class="tooltip" id="tt-supplier"></div>
                </article>

                <article class="block customer" data-id="customer">
                    <div class="badge" style="background:var(--customer)">CU</div>
                    <h3>Customer Block</h3>
                    <p>Identity, addresses, preferences, and pre-purchase customer data.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">CustomerID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">CustomerAddressID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">CustomerID → Order</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini">No mandatory external API</span></div>
                    <div class="tooltip" id="tt-customer"></div>
                </article>

                <article class="block central order" data-id="order">
                    <div class="hub">Central hub</div>
                    <div class="badge" style="background:var(--order)">OR</div>
                    <h3>Order Block</h3>
                    <p>Core transaction engine linking customer, catalog, payment, and shipping.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">OrderID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">CustomerID → Customer</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">ProductID → Catalog</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">PaymentMethodID / ShippingMethodID</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini api">Fraud / Risk API</span><span class="mini api">Tax Calculation API</span></div>
                    <div class="connector-note">Core references: CustomerID, ProductID, BillingAddressID, ShippingAddressID, PaymentMethodID, ShippingMethodID.</div>
                    <div class="tooltip" id="tt-order"></div>
                </article>

                <article class="block catalog" data-id="catalog">
                    <div class="badge" style="background:var(--catalog)">PC</div>
                    <h3>Product Catalog</h3>
                    <p>Products, categories, teams, stock, and product media.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">ProductID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">CategoryID / TeamID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">SupplierID → Supplier</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini">No mandatory external API</span></div>
                    <div class="tooltip" id="tt-catalog"></div>
                </article>

                <article class="block marketing" data-id="marketing">
                    <div class="badge" style="background:var(--marketing)">MK</div>
                    <h3>Marketing Block</h3>
                    <p>Campaigns, promotions, coupons, featured matches, and customer engagement.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">CampaignID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">PromotionID / CouponID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">CouponID / OrderID</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini api">Email / CRM API</span><span class="mini api">Recommendation API</span><span class="mini api">Analytics API</span></div>
                    <div class="tooltip" id="tt-marketing"></div>
                </article>

                <article class="block payment" data-id="payment">
                    <div class="badge" style="background:var(--payment)">PA</div>
                    <h3>Payment Block</h3>
                    <p>Payment methods, gateway transactions, and refunds.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">PaymentID / PaymentMethodID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">OrderID → Order</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">PaymentID → PaymentTransaction</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini api">Payment Gateway API</span></div>
                    <div class="tooltip" id="tt-payment"></div>
                </article>

                <article class="block shipping" data-id="shipping">
                    <div class="badge" style="background:var(--shipping)">SH</div>
                    <h3>Shipping &amp; Delivery</h3>
                    <p>Shipping methods, rates, carrier tracking, and delivery execution.</p>
                    <div class="group-label">Key relationship fields</div>
                    <div class="field-grid">
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">ShippingMethodID</span></div>
                        <div class="field-chip"><span class="pill pk">PK</span><span class="name">ShipmentID</span></div>
                        <div class="field-chip"><span class="pill fk">FK</span><span class="name">OrderID → Order</span></div>
                    </div>
                    <div class="group-label">External services</div>
                    <div class="mini-grid"><span class="mini api">Shipping Rate API</span><span class="mini api">Carrier Tracking API</span><span class="mini api">Address Validation API</span></div>
                    <div class="tooltip" id="tt-shipping"></div>
                </article>
            </div>
        </div>
    </section>

    <section class="detail" id="dictionary">
        <div class="card">
            <h2 id="detailTitle">Order Block</h2>
            <p class="desc" id="detailDesc"></p>
            <div class="subhead">Main tables and key fields</div>
            <div class="table-list" id="tableList"></div>
        </div>

        <div class="card">
            <div class="subhead" style="margin-top:0">Main relationships</div>
            <ul class="list" id="relationshipList"></ul>

            <div class="subhead">Connected APIs</div>
            <ul class="list" id="apiList"></ul>

            <div class="subhead">Design note</div>
            <p class="desc" id="presentationNote"></p>
        </div>
    </section>

    <div class="footer">
        This ERD page was adapted from the uploaded HTML reference and converted into a Razor Page structure for JerseyNation. fileciteturn0file0
    </div>
</section>

@section Styles {
<style>
:root{
  --charcoal:#313a3d; --dark:#1f5a43; --white:#ffffff; --border:#cfdbd3; --line:#8fb19f;
  --muted:#66766d; --shadow:0 12px 28px rgba(31,90,67,.10);
  --api-bg:#eaf6ef; --api-border:#9cc6ad; --api-text:#1f5a43;
  --tbl-bg:#f8fbf9; --tbl-border:#d9e4dd; --tbl-text:#56665e;
  --order:#dceddf; --customer:#e6f4eb; --catalog:#deefe5; --supplier:#e7f4eb;
  --marketing:#edf7f1; --payment:#e5f2e9; --shipping:#e2f0e7; --admin:#e8efeb; --title:#f4f8f6;
}
*{box-sizing:border-box}
.erd-page-hero{background:linear-gradient(135deg,var(--charcoal) 0%, var(--dark) 100%);color:#fff;padding:40px 24px 28px;border-radius:24px}
.erd-wrap{max-width:1440px;margin:0 auto}
.erd-pill{display:inline-block;border:1px solid rgba(255,255,255,.18);background:rgba(255,255,255,.10);border-radius:999px;padding:6px 12px;font-size:12px;margin-bottom:12px}
.erd-page-hero h1{margin:0 0 10px;font-size:34px}
.erd-page-hero p{margin:0;max-width:1040px;line-height:1.7;color:rgba(255,255,255,.92);font-size:15px}
.hero-actions{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px}
.btn-erd-primary,.btn-erd-outline{border-radius:999px;padding:10px 16px;font-weight:600;text-decoration:none}
.btn-erd-primary{background:#fff;color:var(--dark);border:1px solid #fff}
.btn-erd-primary:hover{background:#f3f7f5;color:var(--dark)}
.btn-erd-outline{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.22)}
.btn-erd-outline:hover{background:rgba(255,255,255,.08);color:#fff}
.erd-intro,.diagram-card,.card,.footer{background:var(--white);border:1px solid var(--border);border-radius:20px;box-shadow:var(--shadow)}
.erd-intro{padding:18px 20px;margin:20px 0 18px;color:var(--muted);line-height:1.7;font-size:14px;display:grid;grid-template-columns:1fr 1fr 1fr;gap:24px;align-items:start}
.erd-intro strong{color:var(--dark)}
.diagram-card{padding:22px;margin-bottom:20px;overflow:visible}
.diagram-title{margin:0 0 6px;color:var(--dark);font-size:22px}
.diagram-text,.hint,.desc{color:var(--muted);line-height:1.7;font-size:14px}
.diagram-text{margin:0 0 12px}
.hint{margin:0 0 16px;font-size:13px}
.diagram{position:relative;min-height:1100px;border:1px dashed var(--border);background:radial-gradient(circle at top left, rgba(31,90,67,.04), transparent 28%),linear-gradient(180deg,#fbfdfb 0%, #f5faf7 100%);border-radius:18px;padding:30px 30px 36px;overflow:visible}
.diagram-grid{position:relative;display:grid;grid-template-columns:280px 320px 280px;grid-template-rows:auto auto auto;grid-template-areas:"title admin supplier" "customer order catalog" "shipping payment marketing";column-gap:100px;row-gap:56px;align-items:start;justify-content:center}
.svg-layer{position:absolute;inset:0;width:100%;height:100%;z-index:5;pointer-events:none;overflow:visible}
.block,.title-card{position:relative;background:var(--white);border:1px solid var(--border);border-radius:18px;box-shadow:var(--shadow)}
.title-card{grid-area:title;width:250px;min-height:170px;padding:18px 16px;background:linear-gradient(180deg,var(--title) 0%, #ffffff 100%);display:flex;align-items:center;justify-content:center;text-align:center}
.title-card h2{margin:0;color:var(--dark);font-size:29px;line-height:1.12}
.title-card p{margin:10px 0 0;font-size:12px;color:var(--muted)}
.block{width:250px;min-height:176px;padding:14px;transition:.2s ease transform,.2s ease box-shadow,.2s ease border-color;z-index:2}
.block:hover{transform:translateY(-3px);box-shadow:0 18px 36px rgba(31,90,67,.14);border-color:#a1b9ad;z-index:30}
.block.central{width:300px;min-height:205px;border:2px solid #b8d3c2;background:linear-gradient(180deg,#fcfefc 0%, #f3faf6 100%)}
.block.admin{grid-area:admin}.block.customer{grid-area:customer}.block.marketing{grid-area:marketing}.block.order{grid-area:order}.block.supplier{grid-area:supplier}.block.catalog{grid-area:catalog}.block.shipping{grid-area:shipping}.block.payment{grid-area:payment}
.badge{display:inline-flex;align-items:center;justify-content:center;min-width:36px;height:26px;padding:0 10px;border-radius:9px;font-weight:700;font-size:12px;color:var(--dark);margin-bottom:8px}
.hub{position:absolute;top:12px;right:12px;border-radius:999px;background:#edf7f1;border:1px solid #b7d4c2;color:var(--dark);padding:4px 8px;font-size:10px;font-weight:700}
.block h3{margin:0 0 6px;font-size:15px;line-height:1.2;color:var(--charcoal)} .block p{margin:0 0 8px;font-size:12px;line-height:1.5;color:var(--muted)}
.group-label{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:#5d6f66;margin:8px 0 5px;font-weight:700}
.field-grid{display:grid;gap:5px}.field-chip{display:flex;align-items:center;gap:6px;font-size:10px;line-height:1.25;padding:5px 8px;border-radius:10px;background:var(--tbl-bg);border:1px solid var(--tbl-border);color:var(--tbl-text)}
.field-chip .name{white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.mini-grid{display:flex;flex-wrap:wrap;gap:5px}.mini{display:inline-flex;align-items:center;font-size:10px;line-height:1.25;padding:5px 8px;border-radius:999px;background:var(--tbl-bg);border:1px solid var(--tbl-border);color:var(--tbl-text);white-space:nowrap}
.mini.api{background:var(--api-bg);border-color:var(--api-border);color:var(--api-text);font-weight:600}
.pill{font-size:9px;padding:2px 6px;border-radius:999px;border:1px solid;white-space:nowrap}.pk{color:#0f5a3a;background:#e8f7ee;border-color:#bde2cc}.fk{color:#5e6a35;background:#f4f8e8;border-color:#d7e2b5}
.connector-note{margin-top:8px;padding-top:8px;border-top:1px solid var(--border);font-size:11px;color:#6f7f77;line-height:1.45}
.tooltip{position:absolute;left:50%;bottom:calc(100% + 12px);transform:translateX(-50%);width:390px;background:#fff;border:1px solid var(--border);border-radius:15px;box-shadow:0 18px 42px rgba(20,45,33,.18);padding:13px;opacity:0;pointer-events:none;transition:.18s ease;z-index:40}
.block:hover .tooltip{opacity:1}.tooltip:after{content:"";position:absolute;left:50%;bottom:-8px;transform:translateX(-50%) rotate(45deg);width:16px;height:16px;background:#fff;border-right:1px solid var(--border);border-bottom:1px solid var(--border)}
.tooltip h4{margin:0 0 7px;color:var(--dark);font-size:15px}.tt-text{margin:0 0 9px;color:var(--muted);font-size:12px;line-height:1.55}
.tt-sub{font-size:10px;text-transform:uppercase;letter-spacing:.06em;color:#5d6f66;margin:9px 0 5px;font-weight:700}.tt-list{display:grid;gap:7px}.tt-item{background:#f8fbf9;border:1px solid var(--border);border-radius:11px;padding:8px 9px}
.tt-item strong{display:block;color:var(--charcoal);font-size:12px;margin-bottom:3px}.tt-item span{display:block;color:var(--muted);font-size:11px;line-height:1.45}.api-row{display:flex;flex-wrap:wrap;gap:6px}
.detail{display:grid;grid-template-columns:1.1fr .9fr;gap:20px}.card{padding:20px}.card h2{margin:0 0 8px;color:var(--dark);font-size:24px}.subhead{margin:18px 0 10px;font-size:13px;color:#446455;text-transform:uppercase;letter-spacing:.06em;font-weight:700}
.table-list{display:grid;gap:12px}.tbl{border:1px solid var(--border);border-radius:14px;overflow:hidden;background:#f8fbf9}.tbl-h{background:#eef6f1;padding:12px 14px;border-bottom:1px solid var(--border)}.tbl-h strong{font-size:14px;color:var(--charcoal)}.tbl-h div{color:var(--muted);font-size:12px;margin-top:4px}
.list{margin:0;padding-left:18px;color:var(--muted);font-size:14px;line-height:1.75}.footer{margin-top:18px;padding:16px 18px;color:var(--muted);font-size:14px;line-height:1.7}
.dd-table{width:100%;border-collapse:collapse;font-size:12px;margin:0}
.dd-table thead tr{background:#eef6f1}
.dd-table th{padding:6px 10px;text-align:left;font-size:10.5px;font-weight:700;color:#446455;text-transform:uppercase;letter-spacing:.05em;border-bottom:2px solid var(--border);white-space:nowrap}
.dd-table td{padding:5px 10px;border-bottom:1px solid #edf3ef;color:var(--charcoal);vertical-align:top;line-height:1.4}
.dd-table tr:last-child td{border-bottom:none}
.dd-table tr:hover td{background:#f3faf6}
.dd-table .col-key{width:58px;text-align:center}
.dd-table .col-field{min-width:140px;font-family:'Courier New',Courier,monospace;font-size:11.5px;font-weight:600}
.dd-table .col-type{width:140px;font-family:'Courier New',Courier,monospace;font-size:11px;color:#2a6b4a}
.dd-table .col-null{width:72px;font-size:11px;text-align:center}
.dd-table .col-desc{color:var(--muted);font-size:11.5px}
.null-yes{color:#9ca3af}.null-no{color:#b45309;font-weight:600}
@@media (max-width:1250px){.detail{grid-template-columns:1fr}.diagram-grid{grid-template-columns:250px 300px 250px;column-gap:64px;row-gap:40px}.block{width:230px}.block.central{width:280px}.title-card{width:230px}}
@@media (max-width:980px){.erd-intro{grid-template-columns:1fr}.diagram{padding:18px;min-height:auto}.svg-layer{display:none}.diagram-grid{grid-template-columns:1fr;grid-template-areas:"title" "admin" "supplier" "customer" "order" "catalog" "marketing" "payment" "shipping";row-gap:16px}.block,.block.central,.title-card{width:100%}.tooltip{position:relative;left:auto;bottom:auto;transform:none;width:auto;opacity:1;margin-top:12px}.tooltip:after{display:none}}
</style>
}

@section Scripts {
<script>
const model = {
