@page
@model ReadModel
@{
    ViewData["Title"] = "Read Jerseys";
}

<div class="page-spacer">
    <section class="section-card mb-4">
        <h1>Read Jerseys</h1>
        <p>
            This page displays the current jersey catalog and provides shortcuts for update and delete operations.
        </p>
    </section>

    <section class="section-card">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="mb-0">Current Catalog</h2>
            <a asp-page="/Create" class="btn btn-primary">Add New Jersey</a>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle crud-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Team</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Audience</th>
                        <th>Color</th>
                        <th>Sale Price</th>
                        <th>Promotion</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Jerseys)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Team</td>
                            <td>@item.Name</td>
                            <td>@item.JerseyType</td>
                            <td>@item.Audience</td>
                            <td>@item.Color</td>
                            <td>$@item.SalePrice.ToString("0.00")</td>
                            <td>@(item.IsPromotion ? "Yes" : "No")</td>
                            <td class="d-flex gap-2">
                                <a asp-page="/Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Update</a>
                                <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>