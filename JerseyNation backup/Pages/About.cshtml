
@page
@model AboutModel
@{
    ViewData["Title"] = "About";
}

<section class="about-hero jn-panel mb-4">
    <div class="row g-4 align-items-center">
        <div class="col-lg-7">
            <span class="jn-tag">JerseyNation • Assignment 3</span>
            <h1 class="display-6 fw-bold mt-3 mb-3">About JerseyNation</h1>
            <p class="lead mb-3">
                JerseyNation is an e-commerce website focused on national team jerseys and related football products.
                This project was built as an individual assignment and combines storefront design, product organization,
                data modeling, and interactive pages for analytics and business presentation.
            </p>
            <p class="mb-0">
                The data model below presents the top business view of the ERD. You can hover each block to preview its role,
                key entities, and relationships. When you click the diagram or the link button, a dedicated page opens with
                more details from the ERD and the full data dictionary.
            </p>
        </div>

        <div class="col-lg-5">
            <div class="jn-info-card">
                <h2 class="h5 mb-3">Project summary</h2>
                <ul class="jn-bullets mb-0">
                    <li><strong>Student:</strong> Alessandro Luiz Sica de Almeida</li>
                    <li><strong>Project:</strong> JerseyNation</li>
                    <li><strong>Focus:</strong> E-commerce website for national team jerseys</li>
                    <li><strong>Data modeling:</strong> ERD and Data Dictionary available in detail view</li>
                </ul>
            </div>
        </div>
    </div>
</section>

<section class="jn-panel mb-4">
    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3 mb-3">
        <div>
            <span class="jn-tag">Data Model</span>
            <h2 class="h3 mt-2 mb-2">Interactive ERD preview</h2>
            <p class="text-light-soft mb-0">
                Hover any block to see a short description. Click the diagram to open the page with the full ERD and a more detailed data dictionary.
            </p>
        </div>

        <div class="d-flex gap-2 flex-wrap">
            <a class="btn btn-jn-outline" asp-page="/ERD">Open ERD</a>
            <a class="btn btn-jn-primary" asp-page="/ERD">Link</a>
        </div>
    </div>

    <a asp-page="/ERD" class="erd-preview-link" aria-label="Open full ERD page">
        <div class="erd-preview" id="aboutErdPreview">
            <svg class="erd-lines" id="aboutErdLines"></svg>

            <article class="erd-card erd-title">
                <div>
                    <h3>JerseyNation<br />ERD View</h3>
                    <p>Hover blocks and click to open details</p>
                </div>
            </article>

            <article class="erd-card erd-admin" data-tip="Administration, permissions, audit logs, and internal governance.">
                <div class="erd-badge">AD</div>
                <h4>Administration &amp; Governance</h4>
                <p>Users, permissions, and auditability.</p>
                <div class="erd-tooltip">Administration, permissions, audit logs, and internal governance.</div>
            </article>

            <article class="erd-card erd-supplier" data-tip="Supplier records, purchase orders, and inbound inventory flow.">
                <div class="erd-badge">SU</div>
                <h4>Supplier &amp; Procurement</h4>
                <p>Suppliers, purchase orders, and sourcing.</p>
                <div class="erd-tooltip">Supplier records, purchase orders, and inbound inventory flow.</div>
            </article>

            <article class="erd-card erd-customer" data-tip="Customer account, addresses, preferences, and wish list.">
                <div class="erd-badge">CU</div>
                <h4>Customer Block</h4>
                <p>Identity, addresses, and preferences.</p>
                <div class="erd-tooltip">Customer account, addresses, preferences, and wish list.</div>
            </article>

            <article class="erd-card erd-order erd-central" data-tip="Central transaction hub connecting customer, catalog, payment, and shipping.">
                <span class="erd-hub">Central hub</span>
                <div class="erd-badge">OR</div>
                <h4>Order Block</h4>
                <p>Core transaction engine and checkout flow.</p>
                <div class="erd-tooltip">Central transaction hub connecting customer, catalog, payment, and shipping.</div>
            </article>

            <article class="erd-card erd-catalog" data-tip="Products, categories, teams, inventory, and media assets.">
                <div class="erd-badge">PC</div>
                <h4>Product Catalog</h4>
                <p>Products, teams, stock, and media.</p>
                <div class="erd-tooltip">Products, categories, teams, inventory, and media assets.</div>
            </article>

            <article class="erd-card erd-shipping" data-tip="Shipping methods, freight rates, and tracking events.">
                <div class="erd-badge">SH</div>
                <h4>Shipping &amp; Delivery</h4>
                <p>Methods, rates, and carrier tracking.</p>
                <div class="erd-tooltip">Shipping methods, freight rates, and tracking events.</div>
            </article>

            <article class="erd-card erd-payment" data-tip="Payment methods, transactions, and refunds.">
                <div class="erd-badge">PA</div>
                <h4>Payment Block</h4>
                <p>Methods, gateway events, and refunds.</p>
                <div class="erd-tooltip">Payment methods, transactions, and refunds.</div>
            </article>

            <article class="erd-card erd-marketing" data-tip="Campaigns, promotions, coupons, featured matches, and analytics.">
                <div class="erd-badge">MK</div>
                <h4>Marketing Block</h4>
                <p>Promotions, coupons, and match campaigns.</p>
                <div class="erd-tooltip">Campaigns, promotions, coupons, featured matches, and analytics.</div>
            </article>
        </div>
    </a>
</section>

<section class="jn-panel">
    <div class="row g-4">
        <div class="col-lg-6">
            <h2 class="h4 mb-3">Background</h2>
            <p>
                I completed an HTML course in 1996 and graduated in Advertising. At that time, we created many web pages,
                and I worked with tools such as HotDog, Drumbeat for e-commerce, and Macromedia Flash for dynamic pages.
                Later, I managed large technology teams that built many digital projects, so even when I was not coding directly,
                I remained close to web development and system design.
            </p>
        </div>

        <div class="col-lg-6">
            <h2 class="h4 mb-3">This assignment</h2>
            <p>
                This website was developed as an individual project. In addition to the storefront and content pages,
                the project includes a structured logical data model that supports customers, orders, products, payments,
                shipping, suppliers, and marketing activities. The full ERD page expands this business view into a more detailed
                technical reference with the data dictionary.
            </p>
        </div>
    </div>
</section>

@section Styles {
<style>
    :root {
        --jn-charcoal: #313a3d;
        --jn-green: #1f5a43;
        --jn-green-2: #2a7255;
        --jn-border: #466258;
        --jn-soft: #dfe9e3;
        --jn-soft-2: #eef5f1;
        --jn-white: #ffffff;
        --jn-shadow: 0 16px 34px rgba(0, 0, 0, .18);
    }

    body,
    .about-page,
    .container,
    .text-body,
    p,
    li {
        color: var(--jn-soft);
    }

    .jn-panel {
        background: linear-gradient(180deg, rgba(49,58,61,.96) 0%, rgba(28,35,37,.98) 100%);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 22px;
        padding: 1.6rem;
        box-shadow: var(--jn-shadow);
        color: var(--jn-soft);
    }

    .about-hero {
        background: linear-gradient(135deg, #243033 0%, #1f5a43 100%);
    }

    .jn-tag {
        display: inline-block;
        padding: .38rem .78rem;
        border-radius: 999px;
        border: 1px solid rgba(255,255,255,.18);
        background: rgba(255,255,255,.08);
        color: #fff;
        font-size: .82rem;
        font-weight: 600;
    }

    .text-light-soft,
    .jn-panel p,
    .jn-panel li {
        color: var(--jn-soft);
    }

    .jn-info-card {
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 18px;
        padding: 1rem 1.1rem;
        color: #fff;
    }

    .jn-bullets {
        padding-left: 1.1rem;
        margin: 0;
    }

    .jn-bullets li + li {
        margin-top: .45rem;
    }

    .btn-jn-primary,
    .btn-jn-outline {
        border-radius: 999px;
        padding: .62rem 1.1rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-jn-primary {
        background: var(--jn-green);
        border: 1px solid var(--jn-green);
        color: #fff;
    }

    .btn-jn-primary:hover {
        background: var(--jn-green-2);
        border-color: var(--jn-green-2);
        color: #fff;
    }

    .btn-jn-outline {
        background: transparent;
        border: 1px solid rgba(255,255,255,.22);
        color: #fff;
    }

    .btn-jn-outline:hover {
        background: rgba(255,255,255,.08);
        color: #fff;
    }

    .erd-preview-link {
        display: block;
        text-decoration: none;
        color: inherit;
    }

    .erd-preview {
        position: relative;
        min-height: 760px;
        margin-top: 1rem;
        background: linear-gradient(180deg, #f7fbf8 0%, #edf4f0 100%);
        border: 1px solid #d5e1d9;
        border-radius: 22px;
        padding: 1.5rem;
        overflow: hidden;
        color: #33413b;
    }

    .erd-lines {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 1;
    }

    .erd-card {
        position: absolute;
        background: #fff;
        border: 1px solid #d3dfd7;
        border-radius: 18px;
        padding: .95rem;
        box-shadow: 0 14px 30px rgba(31,90,67,.12);
        z-index: 3;
        width: 220px;
        color: #33413b;
        transition: transform .2s ease, box-shadow .2s ease, border-color .2s ease;
    }

    .erd-card:hover {
        transform: translateY(-3px);
        border-color: #9fb8aa;
        box-shadow: 0 18px 36px rgba(31,90,67,.18);
        z-index: 5;
    }

    .erd-title {
        width: 230px;
        min-height: 170px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        background: linear-gradient(180deg, #eef6f1 0%, #ffffff 100%);
    }

    .erd-title h3,
    .erd-card h4 {
        color: var(--jn-green);
        margin-bottom: .35rem;
    }

    .erd-title p,
    .erd-card p {
        color: #56665e;
        margin: 0;
        font-size: .92rem;
        line-height: 1.45;
    }

    .erd-badge {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 38px;
        height: 28px;
        border-radius: 9px;
        background: #e6f4eb;
        color: var(--jn-green);
        font-weight: 700;
        font-size: .82rem;
        margin-bottom: .5rem;
    }

    .erd-central {
        width: 270px;
        min-height: 185px;
        border: 2px solid #b8d3c2;
        background: linear-gradient(180deg, #fcfefc 0%, #f3faf6 100%);
    }

    .erd-hub {
        position: absolute;
        top: 10px;
        right: 10px;
        border-radius: 999px;
        background: #edf7f1;
        border: 1px solid #b7d4c2;
        color: var(--jn-green);
        padding: .22rem .52rem;
        font-size: .66rem;
        font-weight: 700;
    }

    .erd-tooltip {
        position: absolute;
        left: 50%;
        bottom: calc(100% + 12px);
        transform: translateX(-50%);
        width: 270px;
        background: #fff;
        border: 1px solid #cfdbd3;
        border-radius: 14px;
        box-shadow: 0 18px 42px rgba(20,45,33,.18);
        padding: .8rem .9rem;
        color: #56665e;
        font-size: .85rem;
        line-height: 1.5;
        opacity: 0;
        pointer-events: none;
        transition: opacity .18s ease;
        z-index: 8;
    }

    .erd-tooltip::after {
        content: "";
        position: absolute;
        left: 50%;
        bottom: -8px;
        transform: translateX(-50%) rotate(45deg);
        width: 16px;
        height: 16px;
        background: #fff;
        border-right: 1px solid #cfdbd3;
        border-bottom: 1px solid #cfdbd3;
    }

    .erd-card:hover .erd-tooltip {
        opacity: 1;
    }

    .erd-title { left: 40px; top: 36px; }
    .erd-admin { left: 320px; top: 40px; }
    .erd-supplier { left: 594px; top: 40px; }
    .erd-customer { left: 62px; top: 285px; }
    .erd-order { left: 300px; top: 268px; }
    .erd-catalog { left: 612px; top: 285px; }
    .erd-shipping { left: 60px; top: 540px; }
    .erd-payment { left: 328px; top: 560px; }
    .erd-marketing { left: 612px; top: 540px; }

    @@media (max-width: 991.98px) {
        .erd-preview {
            min-height: auto;
            padding: 1rem;
            display: grid;
            grid-template-columns: 1fr;
            gap: 1rem;
        }

        .erd-lines {
            display: none;
        }

        .erd-card,
        .erd-title,
        .erd-central {
            position: relative;
            inset: auto;
            width: 100%;
            min-height: auto;
        }

        .erd-tooltip {
            position: relative;
            left: auto;
            bottom: auto;
            transform: none;
            width: 100%;
            opacity: 1;
            margin-top: .8rem;
        }

        .erd-tooltip::after {
            display: none;
        }
    }
</style>
}

@section Scripts {
<script>
    (function () {
        const wrap = document.getElementById('aboutErdPreview');
        const svg = document.getElementById('aboutErdLines');
        if (!wrap || !svg) return;

        function point(el, side, frac) {
            const wrapRect = wrap.getBoundingClientRect();
            const r = el.getBoundingClientRect();
            const left = r.left - wrapRect.left;
            const top = r.top - wrapRect.top;
            frac = frac ?? 0.5;

            if (side === 'L') return { x: left, y: top + r.height * frac };
            if (side === 'R') return { x: left + r.width, y: top + r.height * frac };
            if (side === 'T') return { x: left + r.width * frac, y: top };
            return { x: left + r.width * frac, y: top + r.height };
        }

        function connect(a, sideA, fracA, b, sideB, fracB, dashed) {
            const p1 = point(a, sideA, fracA);
            const p2 = point(b, sideB, fracB);
            const path = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            path.setAttribute('d', `M ${p1.x} ${p1.y} L ${p2.x} ${p2.y}`);
            path.setAttribute('fill', 'none');
            path.setAttribute('stroke', dashed ? '#86c9a8' : '#9cc6ad');
            path.setAttribute('stroke-width', dashed ? '1.8' : '2.2');
            path.setAttribute('stroke-linecap', 'round');
            if (dashed) path.setAttribute('stroke-dasharray', '7 6');
            svg.appendChild(path);
        }

        function draw() {
            svg.innerHTML = '';
            svg.setAttribute('width', wrap.clientWidth);
            svg.setAttribute('height', wrap.clientHeight);

            const admin = wrap.querySelector('.erd-admin');
            const supplier = wrap.querySelector('.erd-supplier');
            const customer = wrap.querySelector('.erd-customer');
            const order = wrap.querySelector('.erd-order');
            const catalog = wrap.querySelector('.erd-catalog');
            const shipping = wrap.querySelector('.erd-shipping');
            const payment = wrap.querySelector('.erd-payment');
            const marketing = wrap.querySelector('.erd-marketing');

            if (window.innerWidth < 992) return;

            connect(customer, 'R', 0.45, order, 'L', 0.42, false);
            connect(catalog, 'L', 0.45, order, 'R', 0.42, false);
            connect(payment, 'T', 0.50, order, 'B', 0.52, false);
            connect(admin, 'B', 0.45, order, 'T', 0.42, false);
            connect(supplier, 'B', 0.50, catalog, 'T', 0.50, false);
            connect(marketing, 'T', 0.50, catalog, 'B', 0.50, true);

            const shipTop = point(shipping, 'T', 0.55);
            const orderLeft = point(order, 'L', 0.78);
            const pathShip = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            pathShip.setAttribute('d', `M ${shipTop.x} ${shipTop.y} L ${shipTop.x} 500 L 255 500 L 255 ${orderLeft.y} L ${orderLeft.x} ${orderLeft.y}`);
            pathShip.setAttribute('fill', 'none');
            pathShip.setAttribute('stroke', '#9cc6ad');
            pathShip.setAttribute('stroke-width', '2.2');
            pathShip.setAttribute('stroke-linecap', 'round');
            pathShip.setAttribute('stroke-linejoin', 'round');
            svg.appendChild(pathShip);

            const mktTop = point(marketing, 'T', 0.45);
            const orderBottom = point(order, 'B', 0.78);
            const pathMkt = document.createElementNS('http://www.w3.org/2000/svg', 'path');
            pathMkt.setAttribute('d', `M ${mktTop.x} ${mktTop.y} L ${mktTop.x} 500 L ${orderBottom.x} 500 L ${orderBottom.x} ${orderBottom.y}`);
            pathMkt.setAttribute('fill', 'none');
            pathMkt.setAttribute('stroke', '#86c9a8');
            pathMkt.setAttribute('stroke-width', '1.8');
            pathMkt.setAttribute('stroke-dasharray', '7 6');
            pathMkt.setAttribute('stroke-linecap', 'round');
            pathMkt.setAttribute('stroke-linejoin', 'round');
            svg.appendChild(pathMkt);
        }

        window.addEventListener('load', draw);
        window.addEventListener('resize', draw);
    })();
</script>
}
