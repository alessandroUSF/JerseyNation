@page "{id:int?}"
@model DeleteModel
@{
    ViewData["Title"] = "Delete Jersey";
}

<div class="section-card">
    <h1>Delete Jersey</h1>

    @if (Model.Jersey != null)
    {
        <p>
            You are about to delete <strong>@Model.Jersey.Name</strong> from team <strong>@Model.Jersey.Team</strong>.
        </p>
        <p>
            This action will be recorded in the audit log with the user name and action details.
        </p>

        <form method="post">
            <input asp-for="Id" type="hidden" />

            <div class="mb-3">
                <label class="form-label">Performed By</label>
                <input asp-for="PerformedBy" class="form-control" />
            </div>

            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-page="/Read" class="btn btn-outline-light ms-2">Cancel</a>
        </form>
    }
</div>