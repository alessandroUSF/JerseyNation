@page
@using System.Globalization
@model ReadModel
@{
    ViewData["Title"] = "Read Jerseys";
}

<div class="section-card mb-4">
    @if (Model.Mode == "update")
    {
        <h1>Choose a Jersey to Update</h1>
        <p>Select a jersey below to open the update form.</p>
    }
    else if (Model.Mode == "delete")
    {
        <h1>Choose a Jersey to Delete</h1>
        <p>Select a jersey below to open the delete confirmation page.</p>
    }
    else
    {
        <h1>Read Jerseys</h1>
        <p>Browse the current jersey catalog.</p>
    }
</div>

    <section class="section-card">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <h2 class="mb-0">Current Catalog</h2>
            <a asp-page="/Create" class="btn btn-primary">Add New Jersey</a>
        </div>

        <div class="table-responsive">
            <table class="table table-dark table-hover align-middle crud-table">
                <thead>
                    <tr>
                        <th>ID</th>
                        <th>Team</th>
                        <th>Name</th>
                        <th>Type</th>
                        <th>Audience</th>
                        <th>Color</th>
                        <th>Sale Price</th>
                        <th>Promotion</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Jerseys)
                    {
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.Team</td>
                            <td>@item.Name</td>
                            <td>@item.JerseyType</td>
                            <td>@item.Audience</td>
                            <td>@item.Color</td>
                            <td>$@item.SalePrice.ToString("N2", CultureInfo.GetCultureInfo("en-US"))</td>
                            <td>@(item.IsPromotion ? "Yes" : "No")</td>
                            <td class="crud-actions-cell">
                                <div class="crud-actions">
                                    @if (Model.Mode == "update")
                                    {
                                        <a asp-page="/Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Update</a>
                                    }
                                    else if (Model.Mode == "delete")
                                    {
                                        <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                    }
                                    else
                                    {
                                        <a asp-page="/Update" asp-route-id="@item.Id" class="btn btn-sm btn-outline-light">Update</a>
                                        <a asp-page="/Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger">Delete</a>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>
</div>

<script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
<script src="https://files.bpcontent.cloud/2026/04/18/01/20260418012507-E6EQ81S1.js" defer></script>