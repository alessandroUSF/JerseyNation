@page "{id:int?}"
@model UpdateModel
@{
    ViewData["Title"] = "Update Jersey";
}

<div class="section-card">
    <h1>Update Jersey</h1>

    <form method="post" class="row g-3">
        <input asp-for="Jersey.Id" type="hidden" />

        <div class="col-md-6">
            <label class="form-label">Performed By</label>
            <input asp-for="PerformedBy" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Team</label>
            <input asp-for="Jersey.Team" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Name</label>
            <input asp-for="Jersey.Name" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Jersey Type</label>
            <input asp-for="Jersey.JerseyType" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Audience</label>
            <input asp-for="Jersey.Audience" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Color</label>
            <input asp-for="Jersey.Color" class="form-control" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Jersey Number</label>
            <input asp-for="Jersey.JerseyNumber" class="form-control" type="number" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Cost Price</label>
            <input asp-for="Jersey.CostPrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Sale Price</label>
            <input asp-for="Jersey.SalePrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="col-md-4">
            <label class="form-label">Promo Price</label>
            <input asp-for="Jersey.PromoPrice" class="form-control" type="number" step="0.01" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Available Sizes (comma separated)</label>
            <input asp-for="AvailableSizesText" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Unavailable Sizes (comma separated)</label>
            <input asp-for="UnavailableSizesText" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Primary Image</label>
            <input asp-for="Jersey.PrimaryImage" class="form-control" />
        </div>

        <div class="col-md-6">
            <label class="form-label">Secondary Image</label>
            <input asp-for="Jersey.SecondaryImage" class="form-control" />
        </div>

        <div class="col-12">
            <label class="form-label">Description</label>
            <textarea asp-for="Jersey.Description" class="form-control" rows="3"></textarea>
        </div>

        <div class="col-12 d-flex flex-wrap gap-3">
            <div class="form-check">
                <input asp-for="Jersey.IsPromotion" class="form-check-input" />
                <label class="form-check-label" asp-for="Jersey.IsPromotion">Promotion</label>
            </div>

            <div class="form-check">
                <input asp-for="Jersey.IsSpecial" class="form-check-input" />
                <label class="form-check-label" asp-for="Jersey.IsSpecial">Special</label>
            </div>

            <div class="form-check">
                <input asp-for="Jersey.IsGoalkeeperJersey" class="form-check-input" />
                <label class="form-check-label" asp-for="Jersey.IsGoalkeeperJersey">Goalkeeper</label>
            </div>

            <div class="form-check">
                <input asp-for="Jersey.IsSigned" class="form-check-input" />
                <label class="form-check-label" asp-for="Jersey.IsSigned">Signed</label>
            </div>
        </div>

        <div class="col-12 mt-3">
            <button type="submit" class="btn btn-primary">Update Jersey</button>
            <a asp-page="/Read" class="btn btn-outline-light ms-2">Back to Read</a>
        </div>
    </form>
</div>

<script src="https://cdn.botpress.cloud/webchat/v3.6/inject.js"></script>
<script src="https://files.bpcontent.cloud/2026/04/18/01/20260418012507-E6EQ81S1.js" defer></script>