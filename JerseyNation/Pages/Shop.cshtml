@page
@model ShopModel
@{
    ViewData["Title"] = "Shop";
}
@{
    var cartItems = 0;
}
<div class="shop-page">

    <section class="section-card shop-toolbar mb-4">
        <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3">
            <div class="shop-toolbar-brand">JerseyNation</div>

            <div class="d-flex flex-wrap align-items-center gap-2 shop-toolbar-actions">
                <div class="dropdown">
                    <button class="btn btn-explore dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                        ☰ Explore
                    </button>
                    <ul class="dropdown-menu dropdown-menu-dark">
                        <li><a class="dropdown-item" href="#promotions">🔥 Promotions</a></li>
                        <li><a class="dropdown-item" href="#for-you">⭐ For You</a></li>
                        <li><a class="dropdown-item" href="#special-jerseys">👑 Special Jerseys</a></li>
                        <li><a class="dropdown-item" href="#browse-by-team">🌍 Browse by Team</a></li>
                    </ul>
                </div>

                <form method="get" class="shop-search-form d-flex gap-2" id="shopSearchForm">
                    <input asp-for="Search" class="form-control" placeholder="Search by team, type, color..." id="shopSearchInput" />
                    <button type="submit" class="btn btn-primary">Search</button>
                </form>

                <a asp-page="/Cart" class="btn btn-cart">
                    🛒 Cart
                    <span class="cart-count" style="display:none;"></span>
                </a>
            </div>
        </div>
    </section>


    <section class="top-banner mb-4">
        <img src="/images/top-banner.png" alt="JerseyNation banner" class="top-banner-image" />
    </section>


    <section class="shop-hero mb-3">
        <div class="shop-hero-content">
            <span class="hero-pill">Official jerseys, collector pieces and rare editions</span>
            <h1>Wear the match. Own the moment.</h1>
            <p>
                Discover official national team jerseys, rare signed items and premium match-worn or training-worn pieces curated for fans and collectors.
            </p>

            <div class="hero-actions">
                <a href="#featured-products" class="btn btn-primary">Featured Collection</a>
                <a asp-page="/AllJerseys" class="btn btn-outline-light">View All</a>
                <a href="#next-games" class="btn btn-outline-light">Get Ready for Matches</a>
            </div>
        </div>

        <div class="shop-hero-visual"></div>
    </section>

    <div class="shipping-outside mb-4">
        Fast free shipping on all orders above <strong>US$ 100</strong>
    </div>

    <section id="featured-products" class="mb-4">
        <h2 class="mb-3">Top Picks</h2>

        <div class="row g-4">
            @foreach (var item in Model.FeaturedProducts)
            {
                <div class="col-12 col-md-6 col-xl-4">
                    <div class="section-card product-card h-100">
                        <a asp-page="/ProductDetails"
                               asp-route-id="@item.Id"
                               class="product-image-link track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()">
                            <div class="product-image-frame"
                                 data-primary="@item.PrimaryImage"
                                 data-secondary="@item.SecondaryImage">

                                <button type="button" class="image-nav prev-image" aria-label="Previous image">&#10094;</button>

                                <img src="@item.PrimaryImage"
                                     alt="@item.Name"
                                     class="product-image jersey-zoom" />

                                <button type="button" class="image-nav next-image" aria-label="Next image">&#10095;</button>
                            </div>
                        </a>
                        <div class="product-card-top">
                            <span class="product-team">@item.Team</span>
                        </div>

                        <h3>@item.Name</h3>
                        <p class="product-meta">@item.JerseyType · @item.Audience · @item.Color</p>
                        <p>@item.Description</p>

                        <div class="mb-2">
                            <span class="jersey-badge">@item.JerseyType</span>
                            <span class="jersey-badge">@item.Audience</span>
                            @if (item.IsGoalkeeperJersey)
                            {
                                <span class="jersey-badge">Goalkeeper</span>
                            }
                            @if (item.IsSpecial)
                            {
                                <span class="jersey-badge">Special</span>
                            }
                        </div>

                        <div class="product-footer">
                            <div>
                                @if (item.IsPromotion && item.PromoPrice.HasValue)
                                {
                                    <div>
                                        <span class="old-price">$@item.SalePrice.ToString("0.00")</span>
                                        <span class="promo-badge">Promotion</span>
                                    </div>
                                    <div class="new-price">$@item.PromoPrice.Value.ToString("0.00")</div>
                                }
                                else
                                {
                                    <div class="regular-price">$@item.SalePrice.ToString("0.00")</div>
                                }

                                <div class="sizes-row">
                                    @foreach (var size in item.Sizes)
                                    {
                                        <span class="size-tag">@size</span>
                                    }

                                    @foreach (var size in item.UnavailableSizes)
                                    {
                                        <span class="size-tag unavailable">@size</span>
                                    }
                                </div>
                            </div>

                            <a asp-page="/ProductDetails"
                               asp-route-id="@item.Id"
                               class="btn btn-plus track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()"
                               title="View product details">+</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>

    <section id="next-games" class="mb-4">
        <h2 class="mb-3">Get Ready for Matchday</h2>

        <div class="row g-4">
            @foreach (var match in Model.UpcomingMatches)
            {
                <div class="col-12 col-lg-4">
                    <div class="section-card game-card h-100">
                        <div class="game-teams">
                            <a asp-page="/Shop" asp-route-team="@match.HomeTeam" class="game-team-link game-team-block">
                                <img src="@match.HomeFlagImage" alt="@match.HomeTeam flag" class="match-flag-img" />
                                <span class="match-team-name">@match.HomeTeam</span>
                            </a>

                            <span class="game-vs">vs</span>

                            <a asp-page="/Shop" asp-route-team="@match.AwayTeam" class="game-team-link game-team-block">
                                <img src="@match.AwayFlagImage" alt="@match.AwayTeam flag" class="match-flag-img" />
                                <span class="match-team-name">@match.AwayTeam</span>
                            </a>
                        </div>

                        <p class="match-details"><strong>@match.MatchDate.ToString("MMM dd, yyyy - hh:mm tt")</strong></p>
                        <p class="match-details">@match.Venue</p>

                        @if (match.CanArriveBeforeMatch)
                        {
                            <span class="receive-badge">Receive before match</span>
                        }

                        <div class="mt-3">
                            <a asp-page="/AllJerseys"
                                   asp-route-team1="@match.HomeTeam"
                                   asp-route-team2="@match.AwayTeam"
                                   class="btn btn-primary btn-sm">
                                Buy now
                            </a>
                        </div>


                    </div>
                </div>
            }
        </div>
    </section>

    <section id="promotions" class="mb-4">
        <h2 class="mb-3">Promotions</h2>

        <div class="row g-4">
            @foreach (var item in Model.PromotionProducts)
            {
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="section-card mini-product h-100">
                        <a asp-page="/ProductDetails"
                               asp-route-id="@item.Id"
                               class="product-image-link track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()">
                            <div class="product-image-frame"
                                 data-primary="@item.PrimaryImage"
                                 data-secondary="@item.SecondaryImage">

                                <button type="button" class="image-nav prev-image" aria-label="Previous image">&#10094;</button>

                                <img src="@item.PrimaryImage"
                                     alt="@item.Name"
                                     class="product-image jersey-zoom" />

                                <button type="button" class="image-nav next-image" aria-label="Next image">&#10095;</button>
                            </div>
                        </a>                        
                        <div class="mb-2"><strong>@item.Team</strong></div>
                        <div>@item.Name</div>

                        <div class="mini-product-footer mt-3">
                            @if (item.PromoPrice.HasValue)
                            {
                                <div>
                                    <span class="old-price">$@item.SalePrice.ToString("0.00")</span>
                                    <div class="new-price">$@item.PromoPrice.Value.ToString("0.00")</div>
                                </div>
                            }

                            <a asp-page="/ProductDetails"
                               asp-route-id="@item.Id"
                               class="btn btn-plus track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()"
                               title="View product details">+</a>
                        </div>

                    </div>
                </div>
            }
        </div>
    </section>


    <section id="for-you" class="mb-4">
        <h2 class="mb-3">For You</h2>

        <div class="row g-4">
            @foreach (var item in Model.ForYouProducts)
            {
                <div class="col-12 col-md-6 col-xl-3 for-you-item"
                     data-team="@item.Team"
                     data-audience="@item.Audience"
                     data-jersey-type="@item.JerseyType"
                     data-special="@item.IsSpecial.ToString().ToLower()"
                     data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()"
                     data-promotion="@item.IsPromotion.ToString().ToLower()"
                     data-sizes="@string.Join(",", item.Sizes)">

                    <div class="section-card mini-product h-100">
                        <a asp-page="/ProductDetails" asp-route-id="@item.Id" class="product-image-link track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()">

                            <div class="product-image-frame"
                                 data-primary="@item.PrimaryImage"
                                 data-secondary="@item.SecondaryImage">

                                <button type="button" class="image-nav prev-image" aria-label="Previous image">&#10094;</button>

                                <img src="@item.PrimaryImage"
                                     alt="@item.Name"
                                     class="product-image jersey-zoom" />

                                <button type="button" class="image-nav next-image" aria-label="Next image">&#10095;</button>
                            </div>
                        </a>

                        <div class="mb-2"><strong>@item.Team</strong></div>
                        <div>@item.Name</div>
                        <div class="small mb-2">@item.JerseyType · @item.Audience</div>

                        <div class="mini-product-footer mt-3">
                            <div>
                                @if (item.IsPromotion && item.PromoPrice.HasValue)
                                {
                                    <div>
                                        <span class="old-price">$@item.SalePrice.ToString("0.00")</span>
                                        <span class="promo-badge">Promotion</span>
                                    </div>
                                    <div class="new-price">$@item.PromoPrice.Value.ToString("0.00")</div>
                                }
                                else
                                {
                                    <div class="regular-price">$@item.SalePrice.ToString("0.00")</div>
                                }
                            </div>

                            <a asp-page="/ProductDetails"
                               asp-route-id="@item.Id"
                               class="btn btn-plus track-product-click"
                               data-team="@item.Team"
                               data-audience="@item.Audience"
                               data-jersey-type="@item.JerseyType"
                               data-special="@item.IsSpecial.ToString().ToLower()"
                               data-goalkeeper="@item.IsGoalkeeperJersey.ToString().ToLower()"
                               title="View product details">+</a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>


    <section id="special-jerseys" class="mb-4">
        <h2 class="mb-3">Special jerseys</h2>

        <div class="row g-4">
            @foreach (var item in Model.SpecialProducts)
            {
                <div class="col-12 col-md-6 col-xl-3">
                    <div class="section-card mini-product h-100 special-product">
                        <a asp-page="/ProductDetails" asp-route-id="@item.Id" class="product-image-link">
                            <div class="product-image-frame"
                                 data-primary="@item.PrimaryImage"
                                 data-secondary="@item.SecondaryImage">

                                <button type="button" class="image-nav prev-image" aria-label="Previous image">&#10094;</button>

                                <img src="@item.PrimaryImage"
                                     alt="@item.Name"
                                     class="product-image jersey-zoom" />

                                <button type="button" class="image-nav next-image" aria-label="Next image">&#10095;</button>
                            </div>
                        </a>                        
                        <div class="mb-2"><strong>@item.Team</strong></div>
                        <div>@item.Name</div>

                        <div class="mini-product-footer mt-3">
                            <div>
                                @if (item.IsPromotion && item.PromoPrice.HasValue)
                                {
                                    <div>
                                        <span class="old-price">$@item.SalePrice.ToString("0.00")</span>
                                        <span class="promo-badge">Promotion</span>
                                    </div>
                                    <div class="new-price">$@item.PromoPrice.Value.ToString("0.00")</div>
                                }
                                else
                                {
                                    <div class="regular-price">$@item.SalePrice.ToString("0.00")</div>
                                }
                            </div>

                            <a asp-page="/ProductDetails" asp-route-id="@item.Id" class="btn btn-plus" title="View product details">+</a>
                        </div>

                    </div>
                </div>
            }
        </div>
    </section>

    <section id="browse-by-team" class="section-card mb-4">
        <h2 class="mb-4">Browse by Team</h2>

        @foreach (var group in Model.TeamGroups)
        {
            <div class="team-group-block mb-4">
                <h3 class="team-group-title">@group.GroupName</h3>

                <div class="team-group-grid">
                    @foreach (var team in group.Teams)
                    {
                        <a asp-page="/AllJerseys" asp-route-team="@team.Name" class="team-group-link" title="@team.Name">
                            <img src="@team.FlagImage" alt="@team.Name flag" class="flag-img" />
                            <span class="flag-name">@team.Name</span>
                        </a>
                    }
                </div>
            </div>
        }
    </section>

    <section class="section-card legal-card">
        <p class="mb-2">
            Cookie notice: this prototype uses essential cookies and may connect to future analytics and marketing tools as the platform evolves.
        </p>
        <p class="mb-2">
            Copyright notice: © 2026 JerseyNations. This academic prototype demonstrates e-commerce structure, product presentation and business features.
        </p>
        <p class="mb-0">
            Shipping notice: free fast shipping applies to orders above US$ 100 before taxes and subject to stock availability.
        </p>
    </section>

</div>